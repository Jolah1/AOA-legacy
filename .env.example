# Copy to .env (NEVER commit). For the desktop app, these are read by the
# Rust backend on launch via `dotenvy::dotenv()`. For Netlify, set the same
# names in Site settings -> Environment variables.

# --- SMTP (Gmail) ---
# Use a Google "App Password" (https://myaccount.google.com/apppasswords),
# NOT your account password. 2FA must be enabled on the Google account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=aolanrewaju.akanbi@gmail.com
SMTP_PASS=your-16-char-google-app-password

# Where contact-form notifications go
MAIL_TO=aolanrewaju.akanbi@gmail.com

# Optional friendly From header. If not set, MAIL_FROM defaults to SMTP_USER.
MAIL_FROM=aolanrewaju.akanbi@gmail.com
MAIL_FROM_NAME=AOA Legacy Concepts
